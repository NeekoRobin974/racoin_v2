{
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "twig/twig": "3.*",
        "illuminate/database": "11.*",
        "ext-mysqli": "*",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\Controller\\": "controller/",
            "App\\Model\\": "model/",
            "App\\Db\\": "db/"
        }
    },
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    }
}
